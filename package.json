{
  "name": "artifact-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test:hub": "vitest run src/artifact-hub/*.test.ts skills/artifact-hub/scripts/artifact-hub.test.mjs",
    "test:pr-review": "vitest run skills/pr-review-explorer/assets/template/src/review/*.test.ts && node --test skills/pr-review-explorer/scripts/*.test.mjs",
    "test": "npm run test:hub && npm run test:pr-review"
  },
  "dependencies": {
    "@pierre/diffs": "^1.2.12",
    "dompurify": "^3.2.6",
    "marked": "^16.1.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@testing-library/svelte": "^5.2.8",
    "@types/node": "^26.1.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vite-node": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
